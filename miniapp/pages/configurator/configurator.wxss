.page { padding-bottom: 140rpx; }
.header-bar { background: linear-gradient(135deg, #1a73e8, #0d47a1); padding: 40rpx 30rpx; }
.header-title { display: block; font-size: 36rpx; font-weight: 700; color: #fff; margin-bottom: 8rpx; }
.header-desc { font-size: 26rpx; color: rgba(255,255,255,.7); }
.section { margin: 20rpx; }
.section-header { display: flex; align-items: center; gap: 12rpx; margin-bottom: 16rpx; }
.section-title { font-size: 30rpx; font-weight: 600; color: #333; }
.section-req { font-size: 22rpx; color: #fff; background: #e4393c; padding: 2rpx 14rpx; border-radius: 16rpx; }
.section-opt { font-size: 22rpx; color: #999; background: #f0f0f0; padding: 2rpx 14rpx; border-radius: 16rpx; }
.section-done { font-size: 24rpx; color: #34a853; margin-left: auto; }
.item-scroll { display: flex; white-space: nowrap; padding-bottom: 16rpx; }
.item-card { display: inline-flex; flex-direction: column; width: 200rpx; margin-right: 16rpx; background: #fff; border-radius: 12rpx; padding: 16rpx; border: 3rpx solid transparent; box-shadow: 0 2rpx 8rpx rgba(0,0,0,.06); }
.item-card.active { border-color: #1a73e8; background: #f0f7ff; }
.item-img { width: 168rpx; height: 168rpx; border-radius: 8rpx; background: #f5f5f5; margin-bottom: 12rpx; }
.item-name { font-size: 24rpx; color: #333; line-height: 1.3; display: -webkit-box; -webkit-line-clamp: 2; -webkit-box-orient: vertical; overflow: hidden; white-space: normal; }
.item-price { font-size: 28rpx; color: #e4393c; font-weight: 700; margin-top: 8rpx; }
.summary-bar { position: fixed; bottom: 0; left: 0; right: 0; background: #fff; padding: 16rpx 24rpx; border-top: 2rpx solid #f0f0f0; display: flex; align-items: center; justify-content: space-between; }
.summary-left { flex: 1; }
.summary-label { font-size: 24rpx; color: #999; display: block; }
.summary-total { font-size: 28rpx; color: #333; display: block; margin-top: 4rpx; }
.summary-actions { display: flex; gap: 16rpx; align-items: center; }
.btn-reset { height: 64rpx; line-height: 64rpx; padding: 0 28rpx; border-radius: 32rpx; font-size: 26rpx; border: 2rpx solid #ddd; background: #fff; color: #666; }
.btn-addcart { height: 72rpx; line-height: 72rpx; padding: 0 36rpx; background: #e4393c; color: #fff; border-radius: 36rpx; font-size: 28rpx; border: none; font-weight: 600; }
