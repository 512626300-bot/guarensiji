.page { padding-bottom: 120rpx; }
.empty-state { display: flex; flex-direction: column; align-items: center; padding: 160rpx 0; }
.empty-icon { font-size: 96rpx; margin-bottom: 20rpx; }
.empty-text { font-size: 28rpx; color: #999; margin-bottom: 40rpx; }
.cart-item { display: flex; align-items: center; background: #fff; padding: 20rpx; margin: 2rpx 0; gap: 16rpx; }
.select-box { padding: 10rpx; }
.checkbox { width: 36rpx; height: 36rpx; border-radius: 50%; border: 3rpx solid #ddd; }
.checkbox.checked { background: #1a73e8; border-color: #1a73e8; }
.item-image { width: 160rpx; height: 160rpx; border-radius: 8rpx; background: #f5f5f5; flex-shrink: 0; }
.item-info { flex: 1; min-width: 0; }
.item-name { font-size: 26rpx; color: #333; display: -webkit-box; -webkit-line-clamp: 2; -webkit-box-orient: vertical; overflow: hidden; }
.item-price { display: block; font-size: 30rpx; color: #e4393c; font-weight: 600; margin-top: 8rpx; }
.item-bottom { display: flex; align-items: center; justify-content: space-between; margin-top: 12rpx; }
.item-qty { display: flex; align-items: center; gap: 16rpx; }
.item-subtotal { font-size: 26rpx; color: #e4393c; font-weight: 600; }
.qty-btn { width: 44rpx; height: 44rpx; border-radius: 50%; background: #f5f5f5; display: flex; align-items: center; justify-content: center; font-size: 28rpx; }
.qty-val { font-size: 28rpx; min-width: 40rpx; text-align: center; }
.delete-btn { font-size: 24rpx; color: #999; padding: 10rpx; }
.cart-bottom { position: fixed; bottom: 0; left: 0; right: 0; background: #fff; display: flex; align-items: center; padding: 12rpx 20rpx; border-top: 2rpx solid #f0f0f0; }
.select-all { display: flex; align-items: center; gap: 12rpx; font-size: 26rpx; }
.total-section { flex: 1; text-align: right; margin-right: 20rpx; display: flex; align-items: baseline; justify-content: flex-end; gap: 8rpx; }
.total-label { font-size: 26rpx; color: #666; }
.total-price { font-size: 38rpx; color: #e4393c; font-weight: 700; }
.checkout-btn { height: 72rpx; line-height: 72rpx; padding: 0 48rpx; background: #e4393c; color: #fff; border-radius: 36rpx; font-size: 28rpx; border: none; }
