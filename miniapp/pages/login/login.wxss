.page { display: flex; justify-content: center; align-items: center; min-height: 100vh; padding: 40rpx; }
.login-box { background: #fff; border-radius: 20rpx; padding: 48rpx; width: 100%; max-width: 500rpx; }
.login-title { font-size: 36rpx; font-weight: 700; text-align: center; display: block; margin-bottom: 40rpx; }
.form-group { margin-bottom: 28rpx; }
.form-label { font-size: 26rpx; color: #666; display: block; margin-bottom: 10rpx; }
.form-hint { font-size: 22rpx; color: #ccc; text-align: center; margin-bottom: 24rpx; }
.form-hint text { display: block; }
.toggle { text-align: center; margin-top: 24rpx; font-size: 26rpx; color: #1a73e8; }
