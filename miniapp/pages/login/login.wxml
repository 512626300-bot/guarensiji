<view class="page">
  <view class="login-box">
    <text class="login-title">{{isRegister ? '注册' : '登录'}}</text>
    <view class="form-group">
      <text class="form-label">用户名</text>
      <input class="input" placeholder="请输入用户名" value="{{username}}" bindinput="onUsernameInput"></input>
    </view>
    <view class="form-group">
      <text class="form-label">密码</text>
      <input class="input" type="password" placeholder="请输入密码" value="{{password}}" bindinput="onPasswordInput"></input>
    </view>
    <view class="form-hint">
      <text>测试账号: user / user123</text>
      <text>管理后台: admin / admin123</text>
    </view>
    <button class="btn btn-primary btn-block" bindtap="submit" loading="{{loading}}">
      {{isRegister ? '注册' : '登录'}}
    </button>
    <view class="toggle" bindtap="toggleMode">
      <text>{{isRegister ? '已有账号？去登录' : '没有账号？去注册'}}</text>
    </view>
  </view>
</view>
