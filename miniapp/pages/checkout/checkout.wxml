<view class="page">
  <!-- Address -->
  <view class="address-section" bindtap="selectAddress">
    <view wx:if="{{selectedAddress}}">
      <text class="addr-name">{{selectedAddress.name}} {{selectedAddress.phone}}</text>
      <text class="addr-detail">{{selectedAddress.province}}{{selectedAddress.city}}{{selectedAddress.district}}{{selectedAddress.detail}}</text>
    </view>
    <view wx:else class="addr-empty">
      <text>请选择收货地址</text>
    </view>
    <text class="arrow">›</text>
  </view>

  <!-- Items -->
  <view class="checkout-items">
    <text class="section-title">商品清单</text>
    <view wx:for="{{cartItems}}" wx:key="id" class="checkout-item">
      <image class="ci-image" src="{{item.images && item.images[0]}}" mode="aspectFill"></image>
      <view class="ci-info">
        <text class="ci-name">{{item.name}}</text>
        <text class="ci-price">¥{{item.price}}</text>
      </view>
      <text class="ci-qty">x{{item.quantity}}</text>
    </view>
  </view>

  <!-- Remark -->
  <view class="remark-section">
    <text class="remark-label">备注</text>
    <input class="remark-input" placeholder="选填，如颜色要求等" value="{{remark}}" bindinput="onRemarkInput"></input>
  </view>

  <!-- Bottom -->
  <view class="checkout-bottom">
    <view class="checkout-total">
      <text>合计: </text>
      <text class="checkout-price">¥{{totalAmountText}}</text>
    </view>
    <button class="submit-btn" bindtap="createOrder">提交订单</button>
  </view>
</view>
