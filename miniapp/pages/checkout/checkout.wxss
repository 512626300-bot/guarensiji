.page { padding-bottom: 120rpx; background: #f5f7fa; min-height: 100vh; }
.address-section { background: #fff; padding: 24rpx; margin: 16rpx; border-radius: 12rpx; display: flex; align-items: center; }
.addr-name { font-size: 28rpx; font-weight: 600; display: block; margin-bottom: 8rpx; }
.addr-detail { font-size: 24rpx; color: #999; }
.addr-empty { flex: 1; font-size: 28rpx; color: #999; }
.arrow { font-size: 36rpx; color: #ccc; margin-left: auto; }
.section-title { font-size: 28rpx; font-weight: 600; display: block; margin-bottom: 16rpx; }
.checkout-items { background: #fff; margin: 0 16rpx 16rpx; border-radius: 12rpx; padding: 20rpx; }
.checkout-item { display: flex; align-items: center; gap: 16rpx; margin-bottom: 12rpx; }
.ci-image { width: 120rpx; height: 120rpx; border-radius: 8rpx; background: #f5f5f5; }
.ci-info { flex: 1; }
.ci-name { font-size: 26rpx; display: block; margin-bottom: 8rpx; }
.ci-price { font-size: 28rpx; color: #e4393c; }
.ci-qty { font-size: 24rpx; color: #999; }
.remark-section { background: #fff; margin: 0 16rpx; padding: 20rpx; border-radius: 12rpx; display: flex; align-items: center; gap: 16rpx; }
.remark-label { font-size: 26rpx; flex-shrink: 0; }
.remark-input { flex: 1; font-size: 26rpx; height: 60rpx; }
.checkout-bottom { position: fixed; bottom: 0; left: 0; right: 0; background: #fff; display: flex; align-items: center; padding: 16rpx 24rpx; border-top: 2rpx solid #f0f0f0; }
.checkout-total { flex: 1; text-align: right; margin-right: 20rpx; font-size: 28rpx; }
.checkout-price { font-size: 36rpx; color: #e4393c; font-weight: 700; }
.submit-btn { height: 76rpx; line-height: 76rpx; padding: 0 52rpx; background: #e4393c; color: #fff; border-radius: 38rpx; font-size: 30rpx; border: none; font-weight: 600; }
