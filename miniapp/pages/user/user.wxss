.page { padding: 0; }
.user-header { background: linear-gradient(135deg, #1a73e8, #0d47a1); padding: 60rpx 32rpx; display: flex; align-items: center; gap: 24rpx; }
.avatar { width: 100rpx; height: 100rpx; border-radius: 50%; background: rgba(255,255,255,.2); display: flex; align-items: center; justify-content: center; }
.avatar-text { font-size: 36rpx; color: #fff; }
.user-meta { flex: 1; }
.user-name { font-size: 32rpx; color: #fff; font-weight: 600; }
.order-stats { display: flex; margin: 16rpx; }
.stat-item { flex: 1; text-align: center; padding: 20rpx 0; }
.stat-num { font-size: 40rpx; font-weight: 700; color: #1a73e8; display: block; }
.stat-label { font-size: 24rpx; color: #999; margin-top: 8rpx; display: block; }
.menu-list { margin: 16rpx; }
.menu-item { display: flex; justify-content: space-between; align-items: center; padding: 24rpx 0; font-size: 28rpx; }
.menu-item + .menu-item { border-top: 2rpx solid #f0f0f0; }
.arrow { font-size: 36rpx; color: #ccc; }
