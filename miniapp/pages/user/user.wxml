<view class="page">
  <!-- User header -->
  <view class="user-header">
    <view class="avatar">
      <text wx:if="{{userInfo}}" class="avatar-text">{{userInfo.nickname || userInfo.username}}</text>
      <text wx:else class="avatar-text">?</text>
    </view>
    <view class="user-meta">
      <text wx:if="{{userInfo}}" class="user-name">{{userInfo.nickname || userInfo.username}}</text>
      <button wx:else class="btn btn-primary btn-sm" bindtap="goLogin">点击登录</button>
    </view>
  </view>

  <!-- Order stats -->
  <view class="card order-stats" wx:if="{{userInfo}}">
    <view class="stat-item" data-status="pending" bindtap="goOrders">
      <text class="stat-num">{{orderCounts.pending}}</text>
      <text class="stat-label">待支付</text>
    </view>
    <view class="stat-item" data-status="shipped" bindtap="goOrders">
      <text class="stat-num">{{orderCounts.shipped}}</text>
      <text class="stat-label">待收货</text>
    </view>
    <view class="stat-item" data-status="done" bindtap="goOrders">
      <text class="stat-num">{{orderCounts.done}}</text>
      <text class="stat-label">已完成</text>
    </view>
  </view>

  <!-- Menu -->
  <view class="card menu-list" wx:if="{{userInfo}}">
    <view class="menu-item" bindtap="goAddress">
      <text>📍 收货地址</text>
      <text class="arrow">›</text>
    </view>
    <view class="menu-item" bindtap="logout">
      <text>🚪 退出登录</text>
      <text class="arrow">›</text>
    </view>
  </view>
</view>
