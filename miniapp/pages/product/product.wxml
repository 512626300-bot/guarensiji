<view class="page" wx:if="{{product}}">
  <!-- Product images -->
  <swiper class="image-swiper" indicator-dots autoplay circular>
    <swiper-item wx:for="{{product.images}}" wx:key="*this">
      <image class="swiper-image" src="{{item}}" mode="aspectFill"></image>
    </swiper-item>
  </swiper>

  <!-- Info -->
  <view class="info-section">
    <text class="price">¥{{product.price}}</text>
    <text class="name">{{product.name}}</text>
    <text class="desc" wx:if="{{product.desc}}">{{product.desc}}</text>
    <view class="meta">
      <text>库存: {{product.stock}}</text>
      <text>已售: {{product.sales || 0}}</text>
    </view>
  </view>

  <!-- Quantity selector -->
  <view class="quantity-section">
    <text class="section-label">数量</text>
    <view class="quantity-control">
      <view class="qty-btn" bindtap="decrease">-</view>
      <text class="qty-value">{{quantity}}</text>
      <view class="qty-btn" bindtap="increase">+</view>
    </view>
  </view>

  <!-- Bottom actions -->
  <view class="bottom-bar">
    <button class="btn cart-btn" bindtap="addToCart">加入购物车</button>
    <button class="btn buy-btn" bindtap="buyNow">立即购买</button>
  </view>
</view>

<view wx:if="{{loading}}" class="loading-text">加载中...</view>
