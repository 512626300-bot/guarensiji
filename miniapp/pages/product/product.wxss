.page { padding-bottom: 120rpx; }
.image-swiper { height: 750rpx; }
.swiper-image { width: 100%; height: 750rpx; background: #f5f5f5; }
.info-section { background: #fff; padding: 24rpx; margin: 20rpx; border-radius: 16rpx; }
.price { font-size: 44rpx; color: #e4393c; font-weight: 700; }
.name { display: block; font-size: 32rpx; font-weight: 600; margin-top: 16rpx; color: #333; }
.desc { display: block; font-size: 26rpx; color: #999; margin-top: 12rpx; }
.meta { display: flex; gap: 40rpx; margin-top: 16rpx; font-size: 24rpx; color: #999; }
.quantity-section { background: #fff; margin: 0 20rpx; padding: 24rpx; border-radius: 16rpx; display: flex; justify-content: space-between; align-items: center; }
.section-label { font-size: 28rpx; color: #333; }
.quantity-control { display: flex; align-items: center; gap: 24rpx; }
.qty-btn { width: 48rpx; height: 48rpx; border-radius: 50%; background: #f5f5f5; display: flex; align-items: center; justify-content: center; font-size: 32rpx; color: #333; }
.qty-value { font-size: 32rpx; min-width: 48rpx; text-align: center; }
.bottom-bar { position: fixed; bottom: 0; left: 0; right: 0; display: flex; padding: 16rpx 20rpx; background: #fff; border-top: 2rpx solid #f0f0f0; gap: 20rpx; }
.cart-btn { flex: 1; height: 80rpx; line-height: 80rpx; background: #ffa500; color: #fff; border-radius: 40rpx; text-align: center; font-size: 28rpx; border: none; }
.buy-btn { flex: 1; height: 80rpx; line-height: 80rpx; background: #e4393c; color: #fff; border-radius: 40rpx; text-align: center; font-size: 28rpx; border: none; }
.loading-text { text-align: center; color: #999; padding: 80rpx 0; }
