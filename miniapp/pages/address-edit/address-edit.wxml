<view class="page">
  <view class="card form">
    <view class="form-group">
      <text class="form-label">收货人</text>
      <input class="input" placeholder="请输入收货人姓名" data-field="name" value="{{name}}" bindinput="inputHandler"></input>
    </view>
    <view class="form-group">
      <text class="form-label">手机号</text>
      <input class="input" placeholder="请输入手机号" data-field="phone" value="{{phone}}" bindinput="inputHandler"></input>
    </view>
    <view class="form-group">
      <text class="form-label">省份</text>
      <input class="input" placeholder="省" data-field="province" value="{{province}}" bindinput="inputHandler"></input>
    </view>
    <view class="form-row">
      <view class="form-group flex-1">
        <text class="form-label">城市</text>
        <input class="input" placeholder="市" data-field="city" value="{{city}}" bindinput="inputHandler"></input>
      </view>
      <view class="form-group flex-1">
        <text class="form-label">区/县</text>
        <input class="input" placeholder="区" data-field="district" value="{{district}}" bindinput="inputHandler"></input>
      </view>
    </view>
    <view class="form-group">
      <text class="form-label">详细地址</text>
      <input class="input" placeholder="街道、门牌号等" data-field="detail" value="{{detail}}" bindinput="inputHandler"></input>
    </view>
    <view class="form-group">
      <view class="switch-row" bindtap="toggleDefault">
        <text>设为默认地址</text>
        <view class="switch {{is_default ? 'on' : ''}}">
          <view class="switch-knob"></view>
        </view>
      </view>
    </view>
    <button class="btn btn-primary btn-block" bindtap="save">保存地址</button>
  </view>
</view>
