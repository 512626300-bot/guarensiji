.page { padding: 20rpx; }
.form-group { margin-bottom: 24rpx; }
.form-row { display: flex; gap: 20rpx; }
.flex-1 { flex: 1; }
.form-label { font-size: 26rpx; color: #666; display: block; margin-bottom: 10rpx; }
.switch-row { display: flex; justify-content: space-between; align-items: center; padding: 10rpx 0; font-size: 28rpx; }
.switch { width: 88rpx; height: 48rpx; border-radius: 24rpx; background: #ddd; position: relative; transition: background .2s; }
.switch.on { background: #1a73e8; }
.switch-knob { width: 44rpx; height: 44rpx; border-radius: 50%; background: #fff; position: absolute; top: 2rpx; left: 2rpx; transition: left .2s; box-shadow: 0 2rpx 4rpx rgba(0,0,0,.2); }
.switch.on .switch-knob { left: 42rpx; }
