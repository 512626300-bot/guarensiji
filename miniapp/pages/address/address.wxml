<view class="page">
  <view wx:if="{{!loading && addresses.length === 0}}" class="empty-state">
    <text class="empty-icon">📍</text>
    <text class="empty-text">暂无收货地址</text>
  </view>

  <view wx:for="{{addresses}}" wx:key="id" class="addr-card" data-id="{{item.id}}" bindtap="selectAddress">
    <view class="addr-info">
      <view class="addr-top">
        <text class="addr-name">{{item.name}}</text>
        <text class="addr-phone">{{item.phone}}</text>
        <text class="default-tag" wx:if="{{item.is_default}}">默认</text>
      </view>
      <text class="addr-detail">{{item.province}}{{item.city}}{{item.district}}{{item.detail}}</text>
    </view>
    <view class="addr-actions">
      <text class="edit-btn" data-id="{{item.id}}" bindtap="editAddress">编辑</text>
      <text class="del-btn" data-id="{{item.id}}" bindtap="deleteAddress">删除</text>
    </view>
  </view>

  <view class="add-btn-wrap">
    <button class="btn btn-primary btn-block" bindtap="addAddress">+ 新增地址</button>
  </view>
</view>
