.page { padding-bottom: 120rpx; }
.empty-state { display: flex; flex-direction: column; align-items: center; padding: 120rpx 0; }
.empty-icon { font-size: 72rpx; margin-bottom: 16rpx; }
.empty-text { font-size: 28rpx; color: #999; }
.addr-card { background: #fff; padding: 24rpx; margin: 16rpx; border-radius: 12rpx; }
.addr-top { display: flex; align-items: center; gap: 12rpx; margin-bottom: 8rpx; }
.addr-name { font-size: 28rpx; font-weight: 600; }
.addr-phone { font-size: 26rpx; color: #666; }
.default-tag { font-size: 20rpx; background: #e8f0fe; color: #1a73e8; padding: 2rpx 12rpx; border-radius: 6rpx; }
.addr-detail { font-size: 26rpx; color: #999; display: block; }
.addr-actions { display: flex; justify-content: flex-end; gap: 24rpx; margin-top: 16rpx; padding-top: 16rpx; border-top: 2rpx solid #f0f0f0; }
.addr-actions text { font-size: 24rpx; }
.edit-btn { color: #1a73e8; }
.del-btn { color: #ea4335; }
.add-btn-wrap { padding: 20rpx; }
