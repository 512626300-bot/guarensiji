.page { padding-bottom: 120rpx; }
.loading-text { text-align: center; color: #999; padding: 80rpx 0; font-size: 28rpx; }
.status-bar { padding: 40rpx 24rpx; display: flex; align-items: center; gap: 16rpx; }
.status-bar.pending { background: #fef3cd; }
.status-bar.paid { background: #d1ecf1; }
.status-bar.shipped { background: #cce5ff; }
.status-bar.done { background: #d4edda; }
.status-bar.canceled { background: #f8d7da; }
.status-icon { font-size: 48rpx; }
.status-title { font-size: 32rpx; font-weight: 600; }
.card { background: #fff; margin: 16rpx 20rpx; border-radius: 12rpx; padding: 24rpx; }
.card-title { font-size: 28rpx; font-weight: 600; margin-bottom: 16rpx; display: block; }
.logistics-info { font-size: 26rpx; color: #666; }
.logistics-card { background: #f8fafc; border-radius: 12rpx; padding: 24rpx; }
.logistics-header { display: flex; align-items: center; justify-content: space-between; margin-bottom: 16rpx; }
.logistics-company { font-size: 28rpx; font-weight: 600; color: #333; }
.logistics-status { font-size: 22rpx; color: #1a73e8; background: #e8f0fe; padding: 4rpx 16rpx; border-radius: 20rpx; }
.tracking-row { display: flex; align-items: center; gap: 12rpx; background: #fff; border-radius: 8rpx; padding: 16rpx; margin-bottom: 16rpx; }
.tracking-label { font-size: 24rpx; color: #999; flex-shrink: 0; }
.tracking-no { flex: 1; font-size: 28rpx; font-weight: 700; color: #333; letter-spacing: 2rpx; }
.copy-btn { font-size: 22rpx; color: #1a73e8; border: 1rpx solid #1a73e8; padding: 4rpx 16rpx; border-radius: 20rpx; flex-shrink: 0; }
.log-timeline { position: relative; }
.log-item { display: flex; gap: 16rpx; padding: 12rpx 0; }
.log-dot { width: 12rpx; height: 12rpx; border-radius: 50%; background: #1a73e8; margin-top: 8rpx; flex-shrink: 0; position: relative; z-index: 1; }
.log-item:not(:last-child)::after { content: ''; position: absolute; left: 5rpx; top: 24rpx; width: 2rpx; height: 100%; background: #e0e0e0; }
.log-content { flex: 1; }
.log-desc { font-size: 26rpx; color: #333; display: block; }
.log-time { font-size: 22rpx; color: #999; display: block; margin-top: 4rpx; }
.log-empty { text-align: center; font-size: 24rpx; color: #999; padding: 32rpx 0; }
.logistics-pending { text-align: center; padding: 40rpx 24rpx; }
.logistics-hint { font-size: 24rpx; color: #999; display: block; margin-top: 12rpx; }
.addr-name { font-size: 28rpx; font-weight: 600; display: block; margin-bottom: 6rpx; }
.addr-detail { font-size: 26rpx; color: #666; }
.order-item { display: flex; gap: 16rpx; margin-bottom: 16rpx; }
.oi-image { width: 120rpx; height: 120rpx; border-radius: 8rpx; background: #f5f5f5; }
.oi-info { flex: 1; }
.oi-name { font-size: 26rpx; display: block; margin-bottom: 8rpx; }
.oi-price { font-size: 26rpx; color: #e4393c; }
.order-summary { border-top: 2rpx solid #f0f0f0; padding-top: 16rpx; margin-top: 8rpx; }
.order-summary text { display: block; font-size: 24rpx; color: #999; margin-bottom: 6rpx; }
.total-amount { font-size: 30rpx; color: #e4393c; font-weight: 700; margin-top: 8rpx !important; }
.action-bar { position: fixed; bottom: 0; left: 0; right: 0; background: #fff; display: flex; gap: 20rpx; padding: 16rpx 20rpx; border-top: 2rpx solid #f0f0f0; justify-content: flex-end; }
.action-bar .btn { height: 72rpx; line-height: 72rpx; padding: 0 36rpx; border-radius: 36rpx; font-size: 28rpx; border: none; }
