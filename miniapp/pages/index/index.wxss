.page { min-height: 100vh; background: #f5f7fa; }

/* Header */
.store-header { background: linear-gradient(135deg,#1a73e8,#0d47a1); padding: 48rpx 20rpx 40rpx; }
.store-name { display: block; font-size: 40rpx; font-weight: 700; color: #fff; margin-bottom: 8rpx; }
.store-desc { font-size: 26rpx; color: rgba(255,255,255,.7); }

/* Configurator banner */
.config-banner { background: linear-gradient(135deg, #1a1a2e, #16213e); margin: -20rpx 0 20rpx 0; border-radius: 0; padding: 28rpx 20rpx; display: flex; align-items: center; justify-content: space-between; box-shadow: 0 4rpx 16rpx rgba(0,0,0,.15); }
.config-text { flex: 1; }
.config-title { font-size: 30rpx; font-weight: 700; color: #fff; display: block; margin-bottom: 6rpx; }
.config-desc { font-size: 24rpx; color: rgba(255,255,255,.55); }
.config-arrow { font-size: 44rpx; color: rgba(255,255,255,.35); }

/* Category grid */
.group-grid { display: grid; grid-template-columns: 1fr 1fr; gap: 16rpx; padding: 0 0 20rpx 0; }
.group-card { border-radius: 16rpx; padding: 24rpx; display: flex; flex-direction: column; align-items: center; }
.group-icon { font-size: 64rpx; display: block; margin-bottom: 12rpx; }
.group-name { font-size: 28rpx; font-weight: 600; color: #fff; display: block; }
.group-desc { font-size: 22rpx; color: rgba(255,255,255,.7); margin-top: 4rpx; display: block; }

/* Product section */
.product-section { padding: 0 20rpx 40rpx; }
.section-header { display: flex; align-items: center; justify-content: space-between; margin: 8rpx 0 16rpx; }
.section-title { font-size: 30rpx; font-weight: 600; color: #333; }
.section-clear { font-size: 24rpx; color: #1a73e8; }

.product-item { background: #fff; border-radius: 12rpx; margin-bottom: 16rpx; padding: 20rpx; display: flex; gap: 20rpx; box-shadow: 0 2rpx 8rpx rgba(0,0,0,.04); }
.p-img { width: 180rpx; height: 180rpx; border-radius: 8rpx; background: #f5f5f5; flex-shrink: 0; }
.p-info { flex: 1; min-width: 0; display: flex; flex-direction: column; justify-content: space-between; }
.p-name { font-size: 28rpx; font-weight: 600; color: #333; display: -webkit-box; -webkit-line-clamp: 2; -webkit-box-orient: vertical; overflow: hidden; line-height: 1.4; }
.p-desc { font-size: 24rpx; color: #999; margin-top: 8rpx; display: -webkit-box; -webkit-line-clamp: 1; -webkit-box-orient: vertical; overflow: hidden; }
.p-bottom { display: flex; justify-content: space-between; align-items: center; margin-top: 12rpx; }
.p-price { font-size: 34rpx; color: #e4393c; font-weight: 700; }
.p-tag { font-size: 20rpx; color: #1a73e8; background: #e8f0fe; padding: 4rpx 14rpx; border-radius: 20rpx; }
.state-text { text-align: center; color: #999; font-size: 26rpx; padding: 40rpx 0; }
